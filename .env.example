# ─────────────────────────────────────────────────────────────
# AI Provider — configure ONE (priority: OpenRouter → Anthropic → OpenAI)
# ─────────────────────────────────────────────────────────────

# Option A — OpenRouter (recommended — single key, access to every model)
# Get your key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Any model from https://openrouter.ai/models (default: anthropic/claude-sonnet-4.5)
# Other strong picks:
#   openai/gpt-4o-mini           — cheapest, fast
#   openai/gpt-4o                — balanced
#   anthropic/claude-opus-4      — highest quality, slower
#   google/gemini-2.5-pro        — great for structured output
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
# Optional — attribution headers shown in OpenRouter dashboard
OPENROUTER_REFERER=https://proposal-generator.local
OPENROUTER_TITLE=Proposal Generator

# Option B — Anthropic direct
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Option C — OpenAI direct
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────────────────────
# Shared Postgres (Step 4) — same instance the scraper uses. Forge owns the
# `proposals` schema; scraper owns `public`. Prisma + Next.js both read this.
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/proposal_scraper?schema=proposals

# ─────────────────────────────────────────────────────────────
# Scraper service (for Step 3+ EnrichedCompany contract)
# ─────────────────────────────────────────────────────────────
# Base URL of the website_scraper FastAPI service that exposes
# GET /api/v1/enriched/{analysis_id}. No trailing slash.
SCRAPER_BASE_URL=http://localhost:8000

# ─────────────────────────────────────────────────────────────
# RAG — authentic voice layer (Step 13)
# Phavella expertise RAG: architecture patterns, team bios, proof points.
# No trailing slash. Omit or leave blank to disable RAG (proposals still
# generate — sections fall back to pure LLM output).
# ─────────────────────────────────────────────────────────────
RAG_URL=https://par1kahl.kronus.tech

# ─────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Proposal Generator
PORT=3000
