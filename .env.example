# ─────────────────────────────────────────────────────────────
# AI Provider — configure ONE (priority: OpenRouter → Anthropic → OpenAI)
# ─────────────────────────────────────────────────────────────

# Option A — OpenRouter (recommended — single key, access to every model)
# Get your key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Any model from https://openrouter.ai/models (default: anthropic/claude-sonnet-4.5)
# Other strong picks:
#   openai/gpt-4o-mini           — cheapest, fast
#   openai/gpt-4o                — balanced
#   anthropic/claude-opus-4      — highest quality, slower
#   google/gemini-2.5-pro        — great for structured output
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
# Optional — attribution headers shown in OpenRouter dashboard
OPENROUTER_REFERER=https://proposalforge.local
OPENROUTER_TITLE=ProposalForge

# Option B — Anthropic direct
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Option C — OpenAI direct
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=ProposalForge
PORT=3000
